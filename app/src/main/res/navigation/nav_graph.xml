<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <!-- ═══════════════════════════════════════════════
         SPLASH — يقرر: Onboarding أو Home
    ════════════════════════════════════════════════ -->
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.reda.focusmine.ui.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">

        <action
            android:id="@+id/action_splash_to_onboarding"
            app:destination="@id/onboardingFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- ═══════════════════════════════════════════════
         ONBOARDING — 3 شاشات (ViewPager2 داخل Fragment)
    ════════════════════════════════════════════════ -->
    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.reda.focusmine.ui.OnboardingFragment"
        android:label="Onboarding"
        tools:layout="@layout/fragment_onboarding">

        <action
            android:id="@+id/action_onboarding_to_home"
            app:destination="@id/homeFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popUpTo="@id/onboardingFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- ═══════════════════════════════════════════════
         HOME — Dashboard الرئيسي
    ════════════════════════════════════════════════ -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.reda.focusmine.ui.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_home_to_mission"
            app:destination="@id/missionFragment"
            app:enterAnim="@anim/scale_in"
            app:exitAnim="@anim/fade_out" />
    </fragment>

    <!-- ═══════════════════════════════════════════════
         MISSION — الرادار + الجلسة النشطة
    ════════════════════════════════════════════════ -->
    <fragment
        android:id="@+id/missionFragment"
        android:name="com.reda.focusmine.ui.MissionFragment"
        android:label="Mission"
        tools:layout="@layout/fragment_mission">

        <argument
            android:name="durationMs"
            app:argType="long"
            android:defaultValue="7200000L" />

        <action
            android:id="@+id/action_mission_to_report"
            app:destination="@id/reportFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popUpTo="@id/missionFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- ═══════════════════════════════════════════════
         REPORT — After Action Report (Success/Fail)
    ════════════════════════════════════════════════ -->
    <fragment
        android:id="@+id/reportFragment"
        android:name="com.reda.focusmine.ui.ReportFragment"
        android:label="Report"
        tools:layout="@layout/fragment_report">

        <argument
            android:name="isSuccess"
            app:argType="boolean" />

        <argument
            android:name="durationMs"
            app:argType="long" />

        <action
            android:id="@+id/action_report_to_home"
            app:destination="@id/homeFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popUpTo="@id/reportFragment"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>
