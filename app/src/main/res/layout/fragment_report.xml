<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808">

    <!-- ═══════════════════════════════════════════
         THE SHAREABLE CARD
    ════════════════════════════════════════════ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/reportCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="60dp"
        android:padding="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnShare"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <!-- Top colored status bar -->
        <View
            android:id="@+id/reportStatusBar"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginBottom="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- FOCUSMINE watermark -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FOCUSMINE"
            android:textColor="#1A1A1A"
            android:textSize="9sp"
            android:fontFamily="@font/rajdhani_bold"
            android:letterSpacing="0.4"
            app:layout_constraintTop_toBottomOf="@id/reportStatusBar"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- [ CLASSIFIED ] -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvClassified"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[ CLASSIFIED ]"
            android:textColor="#1A1A1A"
            android:textSize="9sp"
            android:fontFamily="@font/rajdhani_medium"
            android:letterSpacing="0.2"
            app:layout_constraintTop_toBottomOf="@id/reportStatusBar"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- BIG TITLE -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvReportTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="MISSION\nACCOMPLISHED"
            android:textColor="#00CC44"
            android:textSize="42sp"
            android:fontFamily="@font/rajdhani_bold"
            android:lineSpacingMultiplier="0.88"
            android:letterSpacing="-0.01"
            app:layout_constraintTop_toBottomOf="@id/reportStatusBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tvReportSubtitle"
            app:layout_constraintVertical_chainStyle="packed"
            app:layout_constraintVertical_bias="0.3"/>

        <!-- Subtitle -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvReportSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="OBJECTIVE SECURED"
            android:textColor="#00CC44"
            android:textSize="13sp"
            android:fontFamily="@font/rajdhani_medium"
            android:letterSpacing="0.2"
            app:layout_constraintTop_toBottomOf="@id/tvReportTitle"
            app:layout_constraintBottom_toTopOf="@id/divider1"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Divider -->
        <View android:id="@+id/divider1"
            android:layout_width="0dp" android:layout_height="1dp"
            android:layout_marginTop="24dp" android:layout_marginBottom="24dp"
            android:background="#141414"
            app:layout_constraintTop_toBottomOf="@id/tvReportSubtitle"
            app:layout_constraintBottom_toTopOf="@id/tvReportTime"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- BIG TIME -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvReportTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="02:00:00"
            android:textColor="#00CC44"
            android:textSize="58sp"
            android:fontFamily="@font/rajdhani_bold"
            android:letterSpacing="-0.02"
            app:layout_constraintTop_toBottomOf="@id/divider1"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Time label -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvReportTimeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="TIME SECURED"
            android:textColor="#252525"
            android:textSize="10sp"
            android:fontFamily="@font/rajdhani_medium"
            android:letterSpacing="0.3"
            app:layout_constraintTop_toBottomOf="@id/tvReportTime"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Date -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvReportDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01.01.2025 // 09:00"
            android:textColor="#1A1A1A"
            android:textSize="10sp"
            android:fontFamily="@font/rajdhani_medium"
            android:letterSpacing="0.2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ═══════════════════════════════════════════
         ACTION BUTTONS
    ════════════════════════════════════════════ -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnShare"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp"
        android:text="↑  SHARE REPORT"
        android:textColor="#CC3300"
        android:textSize="13sp"
        android:fontFamily="@font/rajdhani_bold"
        android:letterSpacing="0.2"
        app:strokeColor="#CC3300"
        app:strokeWidth="1dp"
        app:cornerRadius="0dp"
        app:rippleColor="#1ACC3300"
        app:layout_constraintBottom_toTopOf="@id/btnBackHome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackHome"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginBottom="32dp"
        android:text="← RETURN TO BASE"
        android:textColor="#2A2A2A"
        android:textSize="12sp"
        android:fontFamily="@font/rajdhani_medium"
        android:letterSpacing="0.15"
        app:rippleColor="#0AFF0000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
