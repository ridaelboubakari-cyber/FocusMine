<!-- 
    fragment_report.xml — PHASE 3
    CHANGES:
      + tvReportGoal       ← microGoal display
      + tvCompromiseCount  ← appLeftCount (failure only)
      + tvReportExcuse     ← excuse (failure only)
      + btnGeneratePdf     ← saves session PDF to Downloads
 -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#080808" android:fillViewport="true">
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="700dp">
<!--  SHAREABLE CARD  -->
<androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/reportCard" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="24dp" android:layout_marginEnd="24dp" android:layout_marginTop="52dp" android:padding="28dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
<View android:id="@+id/reportStatusBar" android:layout_width="0dp" android:layout_height="2dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvWatermark" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="FOCUSMINE" android:textColor="#1A1A1A" android:textSize="9sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.4" app:layout_constraintTop_toBottomOf="@id/reportStatusBar" app:layout_constraintStart_toStartOf="parent"/>
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvClassified" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="[ CLASSIFIED ]" android:textColor="#1A1A1A" android:textSize="9sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.2" app:layout_constraintTop_toBottomOf="@id/reportStatusBar" app:layout_constraintEnd_toEndOf="parent"/>
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvReportTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="MISSION\nACCOMPLISHED" android:textColor="#00CC44" android:textSize="40sp" android:fontFamily="@font/rajdhani_bold" android:lineSpacingMultiplier="0.88" android:letterSpacing="-0.01" app:layout_constraintTop_toBottomOf="@id/tvWatermark" app:layout_constraintStart_toStartOf="parent"/>
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvReportSubtitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="OBJECTIVE SECURED" android:textColor="#00CC44" android:textSize="13sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.2" app:layout_constraintTop_toBottomOf="@id/tvReportTitle" app:layout_constraintStart_toStartOf="parent"/>
<!--  MICRO-GOAL — shows what was committed to  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvReportGoal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="" android:textColor="#333333" android:textSize="12sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.05" android:maxLines="2" android:ellipsize="end" android:lineSpacingMultiplier="1.3" app:layout_constraintTop_toBottomOf="@id/tvReportSubtitle" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<View android:id="@+id/divider1" android:layout_width="0dp" android:layout_height="1dp" android:layout_marginTop="20dp" android:background="#141414" app:layout_constraintTop_toBottomOf="@id/tvReportGoal" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvReportTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="02:00:00" android:textColor="#00CC44" android:textSize="54sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="-0.02" app:layout_constraintTop_toBottomOf="@id/divider1" app:layout_constraintStart_toStartOf="parent"/>
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvReportTimeLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="TIME SECURED" android:textColor="#252525" android:textSize="10sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.3" app:layout_constraintTop_toBottomOf="@id/tvReportTime" app:layout_constraintStart_toStartOf="parent"/>
<!--  COMPROMISE COUNT — failure only  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvCompromiseCount" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="" android:textColor="#CC3300" android:textSize="11sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.15" android:visibility="gone" app:layout_constraintTop_toBottomOf="@id/tvReportTimeLabel" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  EXCUSE SECTION — failure only  -->
<View android:id="@+id/excuseDivider" android:layout_width="0dp" android:layout_height="1dp" android:layout_marginTop="14dp" android:background="#1A0000" android:visibility="gone" app:layout_constraintTop_toBottomOf="@id/tvCompromiseCount" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvExcuseLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="YOUR EXCUSE" android:textColor="#440000" android:textSize="9sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.3" android:visibility="gone" app:layout_constraintTop_toBottomOf="@id/excuseDivider" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvReportExcuse" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="" android:textColor="#551111" android:textSize="13sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.03" android:lineSpacingMultiplier="1.3" android:visibility="gone" app:layout_constraintTop_toBottomOf="@id/tvExcuseLabel" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvReportDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="01.01.2025 // 09:00" android:textColor="#1A1A1A" android:textSize="10sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.2" app:layout_constraintTop_toBottomOf="@id/tvReportExcuse" app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
<!--  BUTTONS  -->
<com.google.android.material.button.MaterialButton android:id="@+id/btnShare" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="54dp" android:layout_marginStart="24dp" android:layout_marginEnd="24dp" android:layout_marginTop="16dp" android:text="↑ SHARE REPORT" android:textColor="#CC3300" android:textSize="13sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.2" app:strokeColor="#CC3300" app:strokeWidth="1dp" app:cornerRadius="0dp" app:layout_constraintTop_toBottomOf="@id/reportCard" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<com.google.android.material.button.MaterialButton android:id="@+id/btnGeneratePdf" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="54dp" android:layout_marginStart="24dp" android:layout_marginEnd="24dp" android:layout_marginTop="10dp" android:text="⬇ SAVE SESSION PDF" android:textColor="#444444" android:textSize="12sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.1" app:strokeColor="#222222" app:strokeWidth="1dp" app:cornerRadius="0dp" app:layout_constraintTop_toBottomOf="@id/btnShare" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<com.google.android.material.button.MaterialButton android:id="@+id/btnBackHome" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="wrap_content" android:layout_height="48dp" android:layout_marginTop="8dp" android:layout_marginBottom="32dp" android:text="← RETURN TO BASE" android:textColor="#2A2A2A" android:textSize="12sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.15" app:layout_constraintTop_toBottomOf="@id/btnGeneratePdf" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
