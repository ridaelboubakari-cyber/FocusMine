<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android" 
    xmlns:app="http://schemas.android.com/apk/res-auto" 
    android:layout_width="match_parent" 
    android:layout_height="match_parent" 
    android:background="#080808"> 

    <com.google.android.material.textview.MaterialTextView 
        android:id="@+id/splashTitle" 
        android:layout_width="wrap_content" 
        android:layout_height="wrap_content" 
        android:text="FOCUSMINE" 
        android:textColor="#CC3300" 
        android:textSize="28sp" 
        android:textStyle="bold" 
        android:letterSpacing="0.5" 
        android:fontFamily="@font/rajdhani_bold" 
        app:layout_constraintTop_toTopOf="parent" 
        app:layout_constraintBottom_toTopOf="@id/splashTagline" 
        app:layout_constraintStart_toStartOf="parent" 
        app:layout_constraintEnd_toEndOf="parent" 
        app:layout_constraintVertical_chainStyle="packed" /> 

    <com.google.android.material.textview.MaterialTextView 
        android:id="@+id/splashTagline" 
        android:layout_width="wrap_content" 
        android:layout_height="wrap_content" 
        android:layout_marginTop="8dp" 
        android:text="CONSEQUENCE ENGINE" 
        android:textColor="#2A2A2A" 
        android:textSize="11sp" 
        android:letterSpacing="0.4" 
        android:fontFamily="@font/rajdhani_medium" 
        app:layout_constraintTop_toBottomOf="@id/splashTitle" 
        app:layout_constraintBottom_toBottomOf="parent" 
        app:layout_constraintStart_toStartOf="parent" 
        app:layout_constraintEnd_toEndOf="parent" /> 

</androidx.constraintlayout.widget.ConstraintLayout>
