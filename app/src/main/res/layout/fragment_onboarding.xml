<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808">

    <!-- Page Indicator -->
    <TextView
        android:id="@+id/pageIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="52dp"
        android:layout_marginEnd="24dp"
        android:text="1 / 3"
        android:textColor="#2A2A2A"
        android:textSize="11sp"
        android:fontFamily="@font/rajdhani_medium"
        android:letterSpacing="0.2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- FOCUSMINE label -->
    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="52dp"
        android:layout_marginStart="24dp"
        android:text="FOCUSMINE"
        android:textColor="#CC3300"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.4"
        android:fontFamily="@font/rajdhani_bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ViewPager2 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/onboardingViewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnOnboardingNext"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Next Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOnboardingNext"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="40dp"
        android:text="I UNDERSTAND THE RULES →"
        android:textColor="#CC3300"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:fontFamily="@font/rajdhani_bold"
        app:strokeColor="#CC3300"
        app:strokeWidth="1dp"
        app:cornerRadius="0dp"
        app:rippleColor="#1ACC3300"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
