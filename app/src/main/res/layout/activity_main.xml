<Button android:id="@+id/surrenderButton" android:layout_width="0dp" android:layout_height="64dp" android:layout_marginStart="32dp" android:layout_marginEnd="32dp" android:layout_marginBottom="48dp" android:text="🏳️ أنا أستسلم" android:textSize="18sp" android:textColor="#FFFFFF" android:backgroundTint="#CC0000" android:visibility="gone" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
