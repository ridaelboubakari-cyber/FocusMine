<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808"
    android:keepScreenOn="true">

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/appLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="52dp"
        android:text="FOCUSMINE"
        android:textColor="#CC3300"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.4"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <View
        android:id="@+id/appDot"
        android:layout_width="5dp"
        android:layout_height="5dp"
        android:layout_marginStart="7dp"
        android:background="@drawable/bg_status_dot"
        app:layout_constraintTop_toTopOf="@id/appLabel"
        app:layout_constraintBottom_toBottomOf="@id/appLabel"
        app:layout_constraintStart_toEndOf="@id/appLabel"/>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/versionLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="52dp"
        android:text="v1.0 // ANDROID"
        android:textColor="#1E1E1E"
        android:textSize="10sp"
        android:letterSpacing="0.2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View
        android:id="@+id/topDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_divider_gradient"
        app:layout_constraintTop_toBottomOf="@id/appLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.reda.focusmine.RadarView
        android:id="@+id/radarView"
        android:layout_width="296dp"
        android:layout_height="296dp"
        app:layout_constraintTop_toBottomOf="@id/topDivider"
        app:layout_constraintBottom_toTopOf="@id/statusContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.42"/>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/timerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="02:00:00"
        android:textColor="#E8E8E8"
        android:textSize="54sp"
        android:textStyle="bold"
        android:letterSpacing="-0.02"
        android:includeFontPadding="false"
        app:layout_constraintTop_toTopOf="@id/radarView"
        app:layout_constraintBottom_toBottomOf="@id/radarView"
        app:layout_constraintStart_toStartOf="@id/radarView"
        app:layout_constraintEnd_toEndOf="@id/radarView"
        app:layout_constraintVertical_bias="0.43"
        tools:ignore="SmallSp"/>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/timerUnits"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:text="HH · MM · SS"
        android:textColor="#181818"
        android:textSize="9sp"
        android:letterSpacing="0.5"
        app:layout_constraintTop_toBottomOf="@id/timerText"
        app:layout_constraintStart_toStartOf="@id/radarView"
        app:layout_constraintEnd_toEndOf="@id/radarView"/>

    <LinearLayout
        android:id="@+id/leftPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="6dp"
        app:layout_constraintTop_toTopOf="@id/radarView"
        app:layout_constraintBottom_toBottomOf="@id/radarView"
        app:layout_constraintStart_toStartOf="@id/radarView"
        app:layout_constraintVertical_bias="0.62">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACC"
            android:textColor="#161616"
            android:textSize="8sp"
            android:letterSpacing="0.3"/>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/accelValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textColor="#202020"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <View
            android:layout_width="18dp"
            android:layout_height="1dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:background="#121212"/>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SNS"
            android:textColor="#161616"
            android:textSize="8sp"
            android:letterSpacing="0.3"/>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/sensorStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LIVE"
            android:textColor="#202020"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rightPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_marginEnd="6dp"
        app:layout_constraintTop_toTopOf="@id/radarView"
        app:layout_constraintBottom_toBottomOf="@id/radarView"
        app:layout_constraintEnd_toEndOf="@id/radarView"
        app:layout_constraintVertical_bias="0.62">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STR"
            android:textColor="#161616"
            android:textSize="8sp"
            android:letterSpacing="0.3"/>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/streakValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00"
            android:textColor="#202020"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <View
            android:layout_width="18dp"
            android:layout_height="1dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:background="#121212"/>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SES"
            android:textColor="#161616"
            android:textSize="8sp"
            android:letterSpacing="0.3"/>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/sessionValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="001"
            android:textColor="#202020"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/statusContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/radarView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/statusDot"
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_status_dot"/>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM INITIALIZING"
            android:textColor="#CC3300"
            android:textSize="11sp"
            android:letterSpacing="0.25"
            android:textStyle="bold"
            android:textAllCaps="true"/>
    </LinearLayout>

    <View
        android:id="@+id/bottomDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="108dp"
        android:background="@drawable/bg_divider_gradient"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/missionLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:text="MISSION IN PROGRESS"
        android:textColor="#181818"
        android:textSize="9sp"
        android:letterSpacing="0.3"
        app:layout_constraintBottom_toTopOf="@id/surrenderButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/surrenderButton"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="44dp"
        android:text="ABORT MISSION"
        android:textColor="#CC3300"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.25"
        android:visibility="gone"
        app:strokeColor="#CC3300"
        app:strokeWidth="1dp"
        app:rippleColor="#1ACC3300"
        app:cornerRadius="0dp"
        app:icon="@drawable/ic_warning"
        app:iconTint="#CC3300"
        app:iconGravity="textStart"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.reda.focusmine.ExplodedOverlayView
        android:id="@+id/explodedOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:importantForAccessibility="no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
