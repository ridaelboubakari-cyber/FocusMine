<!-- 
    fragment_onboarding_page_mode.xml
    NEW file — Phase 2
    Place in: app/src/main/res/layout/
 -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#080808" android:fillViewport="true">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="28dp" android:gravity="center_horizontal">
<!--  Title  -->
<com.google.android.material.textview.MaterialTextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:text="HOW DO YOU WANT\nTO BE TREATED?" android:textColor="#E8E8E8" android:textSize="22sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.1" android:lineSpacingMultiplier="1.15"/>
<!--  Divider  -->
<View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="16dp" android:layout_marginBottom="28dp" android:background="#CC3300"/>
<!--  Subtitle  -->
<com.google.android.material.textview.MaterialTextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="32dp" android:text="This choice is permanent.\nYou cannot change it later." android:textColor="#555555" android:textSize="13sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.05" android:lineSpacingMultiplier="1.3"/>
<!--  RECRUIT  -->
<com.google.android.material.button.MaterialButton xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/btnModeRecruit" android:layout_width="match_parent" android:layout_height="72dp" android:layout_marginBottom="14dp" android:text="RECRUIT" android:textColor="#E8E8E8" android:textSize="16sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.2" android:backgroundTint="#333333" app:cornerRadius="0dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
<!--  OPERATIVE  -->
<com.google.android.material.button.MaterialButton xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/btnModeOperative" android:layout_width="match_parent" android:layout_height="72dp" android:layout_marginBottom="14dp" android:text="OPERATIVE" android:textColor="#E8E8E8" android:textSize="16sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.2" android:backgroundTint="#333333" app:cornerRadius="0dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
<!--  GHOST  -->
<com.google.android.material.button.MaterialButton xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/btnModeGhost" android:layout_width="match_parent" android:layout_height="72dp" android:layout_marginBottom="24dp" android:text="GHOST" android:textColor="#E8E8E8" android:textSize="16sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.2" android:backgroundTint="#333333" app:cornerRadius="0dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
<!--  Mode description — updates on selection  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvModeDescription" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="20dp" android:text="" android:textColor="#888888" android:textSize="14sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.05" android:gravity="center" android:lineSpacingMultiplier="1.3"/>
<!--  Lock warning — appears after selection  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvModeWarning" android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone" android:text="" android:textColor="#CC3300" android:textSize="12sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.15" android:gravity="center" android:lineSpacingMultiplier="1.4"/>
</LinearLayout>
</androidx.core.widget.NestedScrollView>
