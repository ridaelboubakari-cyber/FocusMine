<!-- 
    fragment_mission.xml — PHASE 2
    CHANGES:
      + tvMicroGoal         ← shows the pre-contract goal
      + tvEmotionalSnapshot ← shows emotional state before session
      + ironDoorOverlay     ← full-screen Iron Door panel
      + tvIronDoorCountdown ← mandatory wait countdown
      + etExcuse            ← excuse input field
      + tvExcuseValidation  ← validation message
      + btnConfirmAbandon   ← final exit button (locked until valid)
      - accelValue          ← REMOVED (no more sensor display)
      - explodedOverlay     ← REMOVED (no more sensor alarm)
 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/missionRoot" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#080808" android:keepScreenOn="true">
<!--  ═══════════════════════════════════════════════════════  -->
<!--  TOP BAR                                                  -->
<!--  ═══════════════════════════════════════════════════════  -->
<LinearLayout android:id="@+id/topBar" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginStart="24dp" android:layout_marginEnd="24dp" android:layout_marginTop="52dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
<com.google.android.material.textview.MaterialTextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="FOCUSMINE" android:textColor="#CC3300" android:textSize="11sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.4"/>
<View android:id="@+id/appDot" android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="10dp" android:background="@drawable/bg_status_dot"/>
<com.google.android.material.textview.MaterialTextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ACTIVE" android:textColor="#1E1E1E" android:textSize="10sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.2"/>
</LinearLayout>
<!--  TOP DIVIDER  -->
<View android:id="@+id/topDivider" android:layout_width="0dp" android:layout_height="1dp" android:layout_marginTop="8dp" android:layout_marginStart="24dp" android:layout_marginEnd="24dp" android:background="@drawable/bg_divider_gradient" app:layout_constraintTop_toBottomOf="@id/topBar" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  ═══════════════════════════════════════════════════════  -->
<!--  MICRO-GOAL DISPLAY (NEW Phase 2)                         -->
<!--  ═══════════════════════════════════════════════════════  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvMicroGoal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="24dp" android:layout_marginEnd="24dp" android:layout_marginTop="16dp" android:text="" android:textColor="#444444" android:textSize="12sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.1" android:maxLines="2" android:ellipsize="end" app:layout_constraintTop_toBottomOf="@id/topDivider" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  EMOTIONAL SNAPSHOT (NEW Phase 2)  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvEmotionalSnapshot" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="24dp" android:layout_marginEnd="24dp" android:layout_marginTop="4dp" android:text="" android:textColor="#2A2A2A" android:textSize="10sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.05" android:maxLines="1" android:ellipsize="end" app:layout_constraintTop_toBottomOf="@id/tvMicroGoal" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  ═══════════════════════════════════════════════════════  -->
<!--  RADAR VIEW (center)                                      -->
<!--  ═══════════════════════════════════════════════════════  -->
<com.reda.focusmine.RadarView android:id="@+id/radarView" android:layout_width="260dp" android:layout_height="260dp" app:layout_constraintTop_toBottomOf="@id/tvEmotionalSnapshot" app:layout_constraintBottom_toTopOf="@id/timerText" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintVertical_chainStyle="packed" app:layout_constraintVertical_bias="0.45"/>
<!--  ═══════════════════════════════════════════════════════  -->
<!--  TIMER                                                    -->
<!--  ═══════════════════════════════════════════════════════  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/timerText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="00:00:00" android:textColor="#1A1A1A" android:textSize="52sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.05" app:layout_constraintTop_toBottomOf="@id/radarView" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintBottom_toTopOf="@id/statusContainer"/>
<!--  ═══════════════════════════════════════════════════════  -->
<!--  STATUS BAR                                               -->
<!--  ═══════════════════════════════════════════════════════  -->
<LinearLayout android:id="@+id/statusContainer" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center" android:layout_marginStart="24dp" android:layout_marginEnd="24dp" android:layout_marginTop="12dp" app:layout_constraintTop_toBottomOf="@id/timerText" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintBottom_toTopOf="@id/bottomBar">
<View android:id="@+id/statusDot" android:layout_width="6dp" android:layout_height="6dp" android:layout_marginEnd="10dp" android:background="@drawable/bg_status_dot"/>
<com.google.android.material.textview.MaterialTextView android:id="@+id/statusText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="INITIALIZING" android:textColor="#CC3300" android:textSize="13sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.25"/>
</LinearLayout>
<!--  ═══════════════════════════════════════════════════════  -->
<!--  BOTTOM BAR — Mission label + Abandon button             -->
<!--  ═══════════════════════════════════════════════════════  -->
<LinearLayout android:id="@+id/bottomBar" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginStart="24dp" android:layout_marginEnd="24dp" android:layout_marginBottom="40dp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
<com.google.android.material.textview.MaterialTextView android:id="@+id/missionLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="16dp" android:text="PLACE DEVICE FACE DOWN" android:textColor="#333333" android:textSize="11sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.2"/>
<!--  Abandon button — triggers Iron Door, NOT instant exit  -->
<com.google.android.material.button.MaterialButton android:id="@+id/surrenderButton" android:layout_width="match_parent" android:layout_height="52dp" android:visibility="visible" android:text="ABANDON MISSION" android:textColor="#CC3300" android:textSize="13sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.2" android:backgroundTint="#0D0D0D" app:strokeColor="#CC3300" app:strokeWidth="1dp" app:cornerRadius="0dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
</LinearLayout>
<!--  ═══════════════════════════════════════════════════════  -->
<!--  IRON DOOR OVERLAY (NEW Phase 2)                          -->
<!--  Full-screen panel shown when user tries to abandon       -->
<!--  Visibility: GONE by default — shown by MissionFragment   -->
<!--  ═══════════════════════════════════════════════════════  -->
<androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/ironDoorOverlay" android:layout_width="0dp" android:layout_height="0dp" android:background="#080808" android:visibility="gone" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
<!--  Title  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvIronDoorTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="80dp" android:text="YOU LEFT." android:textColor="#CC3300" android:textSize="36sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.15" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  Divider  -->
<View android:id="@+id/ironDoorDivider" android:layout_width="0dp" android:layout_height="1dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="12dp" android:background="#CC3300" app:layout_constraintTop_toBottomOf="@id/tvIronDoorTitle" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  Goal reminder  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvIronDoorGoalReminder" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="20dp" android:text="" android:textColor="#444444" android:textSize="13sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.05" android:lineSpacingMultiplier="1.3" app:layout_constraintTop_toBottomOf="@id/ironDoorDivider" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  Mandatory countdown (shown while waiting)  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvIronDoorCountdown" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:text="" android:textColor="#333333" android:textSize="14sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.1" android:gravity="center" app:layout_constraintTop_toBottomOf="@id/tvIronDoorGoalReminder" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  Excuse prompt label  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvExcusePrompt" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="28dp" android:text="WHY DID YOU LEAVE?" android:textColor="#555555" android:textSize="11sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.3" android:visibility="gone" app:layout_constraintTop_toBottomOf="@id/tvIronDoorCountdown" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  Excuse input  -->
<EditText android:id="@+id/etExcuse" android:layout_width="0dp" android:layout_height="100dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="10dp" android:background="@drawable/bg_excuse_input" android:padding="14dp" android:textColor="#E8E8E8" android:textColorHint="#333333" android:textSize="14sp" android:fontFamily="@font/rajdhani_medium" android:hint="Be honest. No one is watching. Except you." android:inputType="textMultiLine|textCapSentences" android:gravity="top|start" android:visibility="gone" app:layout_constraintTop_toBottomOf="@id/tvExcusePrompt" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  Validation message  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvExcuseValidation" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="8dp" android:text="" android:textColor="#CC3300" android:textSize="11sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.05" android:lineSpacingMultiplier="1.3" android:visibility="gone" app:layout_constraintTop_toBottomOf="@id/etExcuse" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  Confirm abandon button (locked until valid excuse)  -->
<com.google.android.material.button.MaterialButton android:id="@+id/btnConfirmAbandon" android:layout_width="0dp" android:layout_height="52dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="20dp" android:text="RECORD AND EXIT" android:textColor="#CC3300" android:textSize="13sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.2" android:enabled="false" android:alpha="0.3" android:backgroundTint="#0D0D0D" android:visibility="gone" app:strokeColor="#CC3300" app:strokeWidth="1dp" app:cornerRadius="0dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" app:layout_constraintTop_toBottomOf="@id/tvExcuseValidation" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  Cancel — return to session (always visible in overlay)  -->
<com.google.android.material.button.MaterialButton android:id="@+id/btnCancelAbandon" android:layout_width="0dp" android:layout_height="52dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="12dp" android:layout_marginBottom="40dp" android:text="RETURN TO MISSION" android:textColor="#444444" android:textSize="12sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.1" android:backgroundTint="#0D0D0D" app:cornerRadius="0dp" style="@style/Widget.MaterialComponents.Button.TextButton" app:layout_constraintTop_toBottomOf="@id/btnConfirmAbandon" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
