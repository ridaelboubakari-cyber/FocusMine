<!-- 
    fragment_pre_contract.xml
    NEW — Phase 3
    Place in: app/src/main/res/layout/
 -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#080808" android:fillViewport="true">
<androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="700dp">
<!--  TOP BAR  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvPreContractHeader" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="52dp" android:text="FOCUSMINE" android:textColor="#CC3300" android:textSize="10sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.4" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  DIVIDER  -->
<View android:id="@+id/headerDivider" android:layout_width="0dp" android:layout_height="1dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="10dp" android:background="#CC3300" app:layout_constraintTop_toBottomOf="@id/tvPreContractHeader" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  TITLE  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvPreContractTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="32dp" android:text="BEFORE THE MINE\nIS ARMED." android:textColor="#E8E8E8" android:textSize="30sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.05" android:lineSpacingMultiplier="1.1" app:layout_constraintTop_toBottomOf="@id/headerDivider" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  SUBTITLE  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvPreContractSubtitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="10dp" android:text="Define your mission.\nYou will be held to this." android:textColor="#444444" android:textSize="13sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.05" android:lineSpacingMultiplier="1.35" app:layout_constraintTop_toBottomOf="@id/tvPreContractTitle" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  ═══════════════════════════════════════════════════  -->
<!--  GOAL INPUT                                           -->
<!--  ═══════════════════════════════════════════════════  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvGoalLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="40dp" android:text="WHAT EXACTLY WILL YOU DO?" android:textColor="#555555" android:textSize="10sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.3" app:layout_constraintTop_toBottomOf="@id/tvPreContractSubtitle" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<EditText android:id="@+id/etMicroGoal" android:layout_width="0dp" android:layout_height="96dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="10dp" android:background="@drawable/bg_excuse_input" android:padding="14dp" android:textColor="#E8E8E8" android:textColorHint="#2A2A2A" android:textSize="15sp" android:fontFamily="@font/rajdhani_medium" android:hint="e.g. Solve 3 complex number equations" android:inputType="textMultiLine|textCapSentences" android:gravity="top|start" app:layout_constraintTop_toBottomOf="@id/tvGoalLabel" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  Goal word counter  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvGoalCounter" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="6dp" android:text="Minimum 4 words" android:textColor="#2A2A2A" android:textSize="10sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.05" app:layout_constraintTop_toBottomOf="@id/etMicroGoal" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  ═══════════════════════════════════════════════════  -->
<!--  EMOTIONAL SNAPSHOT INPUT                             -->
<!--  ═══════════════════════════════════════════════════  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvSnapshotLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="28dp" android:text="HOW ARE YOU FEELING RIGHT NOW?" android:textColor="#555555" android:textSize="10sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.3" app:layout_constraintTop_toBottomOf="@id/tvGoalCounter" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<EditText android:id="@+id/etEmotionalSnapshot" android:layout_width="0dp" android:layout_height="72dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="10dp" android:background="@drawable/bg_excuse_input" android:padding="14dp" android:textColor="#E8E8E8" android:textColorHint="#2A2A2A" android:textSize="15sp" android:fontFamily="@font/rajdhani_medium" android:hint="e.g. Tired but showing up" android:inputType="textCapSentences" android:maxLines="2" app:layout_constraintTop_toBottomOf="@id/tvSnapshotLabel" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvSnapshotHint" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="6dp" android:text="Optional. This will appear in your Chronicle." android:textColor="#2A2A2A" android:textSize="10sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.05" app:layout_constraintTop_toBottomOf="@id/etEmotionalSnapshot" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  ═══════════════════════════════════════════════════  -->
<!--  COMMIT BUTTON — The Iron Door entrance               -->
<!--  ═══════════════════════════════════════════════════  -->
<!--  Validation message  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/tvCommitValidation" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="20dp" android:text="" android:textColor="#CC3300" android:textSize="11sp" android:fontFamily="@font/rajdhani_medium" android:letterSpacing="0.05" android:visibility="invisible" app:layout_constraintTop_toBottomOf="@id/tvSnapshotHint" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  HOLD TO COMMIT button  -->
<com.google.android.material.button.MaterialButton android:id="@+id/btnCommit" android:layout_width="0dp" android:layout_height="64dp" android:layout_marginStart="28dp" android:layout_marginEnd="28dp" android:layout_marginTop="12dp" android:layout_marginBottom="48dp" android:text="HOLD TO COMMIT" android:textColor="#CC3300" android:textSize="14sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.2" android:enabled="false" android:alpha="0.3" android:backgroundTint="#0D0D0D" app:strokeColor="#CC3300" app:strokeWidth="1dp" app:cornerRadius="0dp" style="@style/Widget.MaterialComponents.Button.OutlinedButton" app:layout_constraintTop_toBottomOf="@id/tvCommitValidation" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
<!--  Commit progress bar (fills on hold)  -->
<View android:id="@+id/commitProgressBar" android:layout_width="0dp" android:layout_height="2dp" android:layout_marginStart="28dp" android:layout_marginTop="-2dp" android:background="#CC3300" android:scaleX="0" android:transformPivotX="0dp" android:visibility="invisible" app:layout_constraintTop_toBottomOf="@id/btnCommit" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintWidth_percent="0.88"/>
</androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
