<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- ⚠ أيقونة تحذير -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/p1Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ARE YOU\nREADY?"
            android:textColor="#CC3300"
            android:textSize="44sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01"
            android:fontFamily="@font/rajdhani_bold"
            android:lineSpacingMultiplier="0.95" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/p1Subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="This is not a timer. This is a consequence engine."
            android:textColor="#555555"
            android:textSize="14sp"
            android:fontFamily="@font/rajdhani_medium"
            android:letterSpacing="0.05" />

        <!-- خط فاصل -->
        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:background="#CC3300" />

        <!-- Rule 1 -->
        <LinearLayout
            android:id="@+id/p1Rule1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="01"
                android:textColor="#CC3300"
                android:textSize="11sp"
                android:fontFamily="@font/rajdhani_bold"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PLACE PHONE FACE DOWN"
                    android:textColor="#E8E8E8"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/rajdhani_bold"
                    android:letterSpacing="0.1" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="The mine arms when your phone is face down. That's your commitment."
                    android:textColor="#3A3A3A"
                    android:textSize="12sp"
                    android:fontFamily="@font/rajdhani_medium"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Rule 2 -->
        <LinearLayout
            android:id="@+id/p1Rule2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="02"
                android:textColor="#CC3300"
                android:textSize="11sp"
                android:fontFamily="@font/rajdhani_bold"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MOVE IT AND IT DETONATES"
                    android:textColor="#E8E8E8"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/rajdhani_bold"
                    android:letterSpacing="0.1" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="You get 3 seconds of grace period. After that — full alarm, max volume."
                    android:textColor="#3A3A3A"
                    android:textSize="12sp"
                    android:fontFamily="@font/rajdhani_medium"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Rule 3 -->
        <LinearLayout
            android:id="@+id/p1Rule3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:orientation="horizontal">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:text="03"
                android:textColor="#CC3300"
                android:textSize="11sp"
                android:fontFamily="@font/rajdhani_bold"
                android:letterSpacing="0.1" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EVERY SESSION IS RECORDED"
                    android:textColor="#E8E8E8"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/rajdhani_bold"
                    android:letterSpacing="0.1" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your wins and failures are logged. The data doesn't lie."
                    android:textColor="#3A3A3A"
                    android:textSize="12sp"
                    android:fontFamily="@font/rajdhani_medium"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Warning box -->
        <LinearLayout
            android:id="@+id/p1Warning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp"
            android:background="#0DCC3300">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠"
                android:textColor="#CC3300"
                android:textSize="16sp"
                android:layout_marginEnd="10dp" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="This app will make noise in public if you fail. You've been warned."
                android:textColor="#CC3300"
                android:textSize="12sp"
                android:fontFamily="@font/rajdhani_medium" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
