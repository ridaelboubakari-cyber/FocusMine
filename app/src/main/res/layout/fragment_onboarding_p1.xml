<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#080808">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="28dp" android:paddingEnd="28dp" android:paddingTop="20dp" android:paddingBottom="24dp">
<!--  p1Title  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/p1Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ARE YOU\nREADY?" android:textColor="#CC3300" android:textSize="48sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="-0.01" android:lineSpacingMultiplier="0.9"/>
<!--  p1Divider  -->
<View android:id="@+id/p1Divider" android:layout_width="48dp" android:layout_height="2dp" android:layout_marginTop="16dp" android:background="#CC3300"/>
<!--  p1Sub  -->
<com.google.android.material.textview.MaterialTextView android:id="@+id/p1Sub" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:layout_marginBottom="28dp" android:text="This is not a productivity timer.\nThis is a consequence engine." android:textColor="#444444" android:textSize="15sp" android:fontFamily="@font/rajdhani_medium" android:lineSpacingMultiplier="1.3"/>
<!--  p1Rule1  -->
<LinearLayout android:id="@+id/p1Rule1" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="20dp">
<com.google.android.material.textview.MaterialTextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="01" android:textColor="#330000" android:textSize="20sp" android:fontFamily="@font/rajdhani_bold"/>
<LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
<com.google.android.material.textview.MaterialTextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PLACE FACE DOWN" android:textColor="#E8E8E8" android:textSize="14sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.1"/>
<com.google.android.material.textview.MaterialTextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="Place your phone face down to arm the mine. That is your commitment." android:textColor="#2E2E2E" android:textSize="13sp" android:fontFamily="@font/rajdhani_medium"/>
</LinearLayout>
</LinearLayout>
<!--  p1Rule2  -->
<LinearLayout android:id="@+id/p1Rule2" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="20dp">
<com.google.android.material.textview.MaterialTextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="02" android:textColor="#330000" android:textSize="20sp" android:fontFamily="@font/rajdhani_bold"/>
<LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
<com.google.android.material.textview.MaterialTextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MOVE IT AND IT DETONATES" android:textColor="#E8E8E8" android:textSize="14sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.1"/>
<com.google.android.material.textview.MaterialTextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="3 seconds of grace. After that — max volume alarm in public." android:textColor="#2E2E2E" android:textSize="13sp" android:fontFamily="@font/rajdhani_medium"/>
</LinearLayout>
</LinearLayout>
<!--  p1Rule3  -->
<LinearLayout android:id="@+id/p1Rule3" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="28dp">
<com.google.android.material.textview.MaterialTextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="03" android:textColor="#330000" android:textSize="20sp" android:fontFamily="@font/rajdhani_bold"/>
<LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
<com.google.android.material.textview.MaterialTextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EVERY SESSION IS LOGGED" android:textColor="#E8E8E8" android:textSize="14sp" android:fontFamily="@font/rajdhani_bold" android:letterSpacing="0.1"/>
<com.google.android.material.textview.MaterialTextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="Your wins. Your failures. All recorded. The data does not lie." android:textColor="#2E2E2E" android:textSize="13sp" android:fontFamily="@font/rajdhani_medium"/>
</LinearLayout>
</LinearLayout>
<!--  p1WarningBox  -->
<LinearLayout android:id="@+id/p1WarningBox" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:background="#0ECC3300">
<com.google.android.material.textview.MaterialTextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚠" android:textColor="#CC3300" android:textSize="18sp" android:layout_marginEnd="10dp"/>
<com.google.android.material.textview.MaterialTextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="This app will make noise in public if you fail. You have been warned." android:textColor="#882200" android:textSize="12sp" android:fontFamily="@font/rajdhani_medium"/>
</LinearLayout>
</LinearLayout>
</ScrollView>
